# Binary (repo-root only - patterns are anchored with a leading "/" so
# they don't accidentally match same-named paths elsewhere in the tree,
# e.g. cmd/agent/ or internal/memory/).
/go-code-agent
/agent

# Runtime data (generated by agent). Actual runtime root is
# .go-code-agent/ (sessions, memory, etc.) - anchored to repo root too.
/.go-code-agent/
/.tasks/
/.team/
/.transcripts/
/memory/
/MEMORY.md

# Build/test artifacts
coverage.out
*.test

# Local shell/readline history
.rl-history

# IDE
.idea/
.vscode/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db
