			}
		})
	}
}

func TestMMRRerank(t *testing.T) {
	results := []scoredChunk{
		{Chunk: memoryChunk{Text: "A"}, Score: 0.9},
		{Chunk: memoryChunk{Text: "B"}, Score: 0.8},
		{Chunk: memoryChunk{Text: "C"}, Score: 0.7},
		{Chunk: memoryChunk{Text: "D"}, Score: 0.6},
	}

	// lambda=0.7 should favor relevance but also diversity
	reranked := mmrRerank(results, 0.7)

	if len(reranked) != len(results) {
		t.Errorf("mmrRerank returned %d results, want %d", len(reranked), len(results))
	}

	// Check that all results are unique
	texts := make(map[string]bool)
	for _, r := range reranked {
		if texts[r.Chunk.Text] {
			t.Error("mmrRerank produced duplicate results")
		}
		texts[r.Chunk.Text] = true
	}
}

func TestDeduplicateResults(t *testing.T) {
	tests := []struct {
		name        string
		results     []scoredChunk
		threshold   float64
		expectedLen int
	}{
		{
			name:        "无重复",
			results:     []scoredChunk{{Chunk: memoryChunk{Text: "A"}, Score: 0.8}, {Chunk: memoryChunk{Text: "B"}, Score: 0.7}},
			threshold:   0.5,
			expectedLen: 2,
		},
		{
			name:        "完全相同",
			results:     []scoredChunk{{Chunk: memoryChunk{Text: "A"}, Score: 0.8}, {Chunk: memoryChunk{Text: "A"}, Score: 0.7}},
			threshold:   0.5,
			expectedLen: 1,
		},
		{
			name:        "高度相似",
			results:     []scoredChunk{{Chunk: memoryChunk{Text: "hello world"}, Score: 0.8}, {Chunk: memoryChunk{Text: "hello world!"}, Score: 0.7}},
			threshold:   0.8,
			expectedLen: 1,
		},
		{
			name:        "轻微相似",
			results:     []scoredChunk{{Chunk: memoryChunk{Text: "hello world"}, Score: 0.8}, {Chunk: memoryChunk{Text: "hello world test"}, Score: 0.7}},
			threshold:   0.9,
			expectedLen: 2,
		},
	}

	for _, tt := range tests {
		t.Run(tt.name, func(t *testing.T) {
			result := deduplicateResults(tt.results, tt.threshold)
			if len(result) != tt.expectedLen {
				t.Errorf("deduplicateResults returned %d results, want %d", len(result), tt.expectedLen)
			}
		})
	}
}

func TestParseEvergreenCategory(t *testing.T) {
	tests := []struct {
		name           string
		input          string
		expectedCategory string
		expectedText    string
	}{
		{
			name:           "带类别前缀",
			input:          "[preference] user likes dark mode",
			expectedCategory: "preference",
			expectedText:    "user likes dark mode",
		},
		{
			name:           "带 lesson 类别",
			input:          "[lesson] always use context manager",
			expectedCategory: "lesson",
			expectedText:    "always use context manager",
		},
		{
			name:           "不带类别前缀",
			input:          "just a plain fact",
			expectedCategory: "fact",
			expectedText:    "just a plain fact",
		},
		{
			name:           "空段落",
			input:          "",
			expectedCategory: "fact",
			expectedText:    "",
		},
		{
			name:           "空格开头",
			input:          "  [preference]  spaced category",
			expectedCategory: "preference",
			expectedText:    "spaced category",
		},
	}

	for _, tt := range tests {
		t.Run(tt.name, func(t *testing.T) {
			category, text := parseEvergreenCategory(tt.input)
			if category != tt.expectedCategory {
				t.Errorf("parseEvergreenCategory(%q) category = %q, want %q", tt.input, category, tt.expectedCategory)
			}
			if text != tt.expectedText {
				t.Errorf("parseEvergreenCategory(%q) text = %q, want %q", tt.input, text, tt.expectedText)
			}
		})
	}
}

