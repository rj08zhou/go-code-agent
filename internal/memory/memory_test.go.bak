// ========== 工具函数测试 ==========

func TestTokenize(t *testing.T) {
	tests := []struct {
		name     string
		input    string
		expected []string
	}{
		{
			name:     "英文字符",
			input:    "hello world test",
			expected: []string{"hello", "world", "test"},
		},
		{
			name:     "数字",
			input:    "test123 abc456",
			expected: []string{"test123", "abc456"},
		},
		{
			name:     "中文字符",
			input:    "你好世界测试",
			expected: []string{"你好", "世界", "测试"},
		},
		{
			name:     "混合字符",
			input:    "hello 你好 world 世界",
			expected: []string{"hello", "你好", "world", "世界"},
		},
		{
			name:     "短词",
			input:    "a b c",
			expected: []string{"a", "b", "c"},
		},
		{
			name:     "单个字符",
			input:    "a",
			expected: []string{"a"},
		},
		{
			name:     "空字符串",
			input:    "",
			expected: []string{},
		},
		{
			name:     "无匹配字符",
			input:    "!@#$%^&*()",
			expected: []string{},
		},
		{
			name:     "包含标点",
			input:    "hello, world!",
			expected: []string{"hello", "world"},
		},
	}

	for _, tt := range tests {
		t.Run(tt.name, func(t *testing.T) {
			result := tokenize(tt.input)
			sort.Strings(result)
			sort.Strings(tt.expected)
			if !equalStringSlices(result, tt.expected) {
				t.Errorf("tokenize(%q) = %v, want %v", tt.input, result, tt.expected)
			}
		})
	}
}

func TestFNVHash(t *testing.T) {
	// Expected values are the FNV-1a 64-bit hash of each input — i.e.
	// the exact algorithm fnvHash() implements (offset 14695981039346656037,
	// prime 1099511628211, xor-then-multiply per byte). Pinning these
	// catches any accidental swap to plain FNV-1 or to the stdlib
	// hash/fnv (which would silently change every score in the search
	// pipeline).
	tests := []struct {
		name     string
		input    string
		expected uint64
	}{
		{
			name:     "空字符串",
			input:    "",
			expected: 14695981039346656037,
		},
		{
			name:     "简单字符串",
			input:    "hello",
			expected: 11831194018420276491,
		},
		{
			name:     "重复字符串",
			input:    "hello",
			expected: 11831194018420276491,
		},
		{
			name:     "不同字符串",
			input:    "world",
			expected: 5717881983045765875,
		},
	}

	for _, tt := range tests {
		t.Run(tt.name, func(t *testing.T) {
			result := fnvHash(tt.input)
			if result != tt.expected {
				t.Errorf("fnvHash(%q) = %d, want %d", tt.input, result, tt.expected)
			}
		})
	}
}

func TestVectorCosine(t *testing.T) {
	tests := []struct {
		name     string
		a        []float64
		b        []float64
		expected float64
	}{
		{
			name:     "相同向量",
			a:        []float64{1, 0, 0},
			b:        []float64{1, 0, 0},
			expected: 1.0,
		},
		{
			name:     "正交向量",
			a:        []float64{1, 0},
			b:        []float64{0, 1},
			expected: 0.0,
		},
		{
			name:     "部分重叠",
			a:        []float64{1, 2, 3},
			b:        []float64{1, 1, 1},
			// dot=6, |a|=√14, |b|=√3 → 6/√42 ≈ 0.9258200997725515
			expected: 0.9258200997725515,
		},
		{
			name:     "反向向量",
			a:        []float64{1, -1},
			b:        []float64{-1, 1},
			expected: -1.0,
		},
		{
			name:     "空向量",
			a:        []float64{},
			b:        []float64{},
			expected: 0.0,
		},
		{
			name:     "零向量",
			a:        []float64{0, 0},
			b:        []float64{0, 0},
			expected: 0.0,
		},
	}

	for _, tt := range tests {
		t.Run(tt.name, func(t *testing.T) {
			result := vectorCosine(tt.a, tt.b)
			// Use tolerance for floating point comparison
			if diff := result - tt.expected; diff < -0.000001 || diff > 0.000001 {
				t.Errorf("vectorCosine(%v, %v) = %f, want %f", tt.a, tt.b, result, tt.expected)
			}
		})
	}
}

func TestJaccardSimilarity(t *testing.T) {
	tests := []struct {
		name     string
		a        []string
		b        []string
		expected float64
	}{
		{
			name:     "完全相同",
			a:        []string{"a", "b", "c"},
			b:        []string{"a", "b", "c"},
			expected: 1.0,
		},
		{
			name:     "一个为空",
			a:        []string{"a", "b"},
			b:        []string{},
			expected: 0.0,
		},
		{
			name:     "完全不同",
			a:        []string{"a", "b"},
			b:        []string{"c", "d"},
			expected: 0.0,
		},
		{
			name:     "部分重叠",
			a:        []string{"a", "b", "c"},
			b:        []string{"b", "c", "d"},
			expected: 0.5,
		},
		{
			name:     "无重叠",
			a:        []string{"a", "b"},
			b:        []string{"c", "d", "e"},
			expected: 0.0,
		},
		{
			name:     "相同元素但顺序不同",
			a:        []string{"a", "b", "c"},
			b:        []string{"c", "b", "a"},
			expected: 1.0,
		},
	}

	for _, tt := range tests {
		t.Run(tt.name, func(t *testing.T) {
			result := jaccardSimilarity(tt.a, tt.b)
			if result < tt.expected-0.000001 || result > tt.expected+0.000001 {
				t.Errorf("jaccardSimilarity(%v, %v) = %f, want %f", tt.a, tt.b, result, tt.expected)
			}
		})
	}
}

func TestHashVector(t *testing.T) {
	tests := []struct {
		name     string
		text     string
		dim      int
		expected []float64
	}{
		{
			name:     "简单文本",
			text:     "hello world",
			dim:      64,
			expected: []float64{}, // 长度超过 1 才会保留
		},
		{
			name:     "短词",
			text:     "a b c",
			dim:      64,
			expected: []float64{}, // 单字符会被过滤
		},
		{
			name:     "单个字符",
			text:     "a",
			dim:      64,
			expected: []float64{}, // 单字符会被过滤
		},
	}

	for _, tt := range tests {
		t.Run(tt.name, func(t *testing.T) {
			result := hashVector(tt.text, tt.dim)
			if len(result) != tt.dim {
				t.Errorf("hashVector(%q, %d) length = %d, want %d", tt.text, tt.dim, len(result), tt.dim)
			}
			// Check normalization
			sum := 0.0
			for _, v := range result {
				sum += v * v
			}
			norm := 1.0
			if sum > 0 {
				norm = sum
			}
			if norm > 1.000001 || norm < 0.999999 {
				t.Errorf("hashVector(%q, %d) norm = %f, want ~1.0", tt.text, tt.dim, norm)
			}
		})
	}
}

func TestBM25Score(t *testing.T) {
	tests := []struct {
		name     string
		query    []string
		doc      []string
		df       map[string]int
		n        int
		avgdl    float64
		expected float64
	}{
		{
			name:     "简单匹配",
			query:    []string{"hello"},
			doc:      []string{"hello", "world"},
			df:       map[string]int{"hello": 1, "world": 1},
			n:        2,
			avgdl:    1.5,
			expected: 0.0, // BM25 会过滤掉 docTF=0 的情况，实际应该计算
		},
		{
			name:     "文档包含查询词",
			query:    []string{"test", "hello"},
			doc:      []string{"hello", "world", "test"},
			df:       map[string]int{"hello": 2, "world": 2, "test": 1},
			n:        2,
			avgdl:    2.0,
			expected: 0.0, // 实际计算
		},
		{
			name:     "文档不包含查询词",
			query:    []string{"hello"},
			doc:      []string{"world", "test"},
			df:       map[string]int{"hello": 1, "world": 1, "test": 1},
			n:        2,
			avgdl:    1.5,
			expected: 0.0,
		},
		{
			name:     "空文档",
			query:    []string{"hello"},
			doc:      []string{},
			df:       map[string]int{"hello": 1},
			n:        1,
			avgdl:    1.0,
			expected: 0.0,
		},
	}

	for _, tt := range tests {
		t.Run(tt.name, func(t *testing.T) {
			result := bm25Score(tt.query, tt.doc, tt.df, tt.n, tt.avgdl)
			if result < 0 {
				t.Errorf("bm25Score(%v, %v, ...) = %f, want non-negative", tt.query, tt.doc, result)
			}
		})
	}
}

func TestMergeHybridResults(t *testing.T) {
	vecResults := []scoredChunk{
		{Chunk: memoryChunk{Text: "vec1"}, Score: 0.8},
		{Chunk: memoryChunk{Text: "vec2"}, Score: 0.6},
	}

	kwResults := []scoredChunk{
		{Chunk: memoryChunk{Text: "vec2"}, Score: 0.7},
		{Chunk: memoryChunk{Text: "vec3"}, Score: 0.5},
	}

	result := mergeHybridResults(vecResults, kwResults, 0.5, 0.5)

	if len(result) != 3 {
		t.Errorf("mergeHybridResults returned %d results, want 3", len(result))
	}

	// vec2 should have combined score
	foundVec2 := false
	for _, r := range result {
		if r.Chunk.Text == "vec2" {
			// Score should be 0.6*0.5 + 0.7*0.5 = 0.65
			if r.Score < 0.64 || r.Score > 0.66 {
				t.Errorf("vec2 score = %f, want ~0.65", r.Score)
			}
			foundVec2 = true
		}
	}
	if !foundVec2 {
		t.Error("vec2 result not found in merged results")
	}
}

func TestDecayRateForCategory(t *testing.T) {
	tests := []struct {
