// ========== MemoryStore 集成测试 ==========

func TestNewMemoryStore(t *testing.T) {
	// Create a temporary directory for testing
	tmpDir := t.TempDir()
	store := NewMemoryStore(tmpDir)

	if store == nil {
		t.Fatal("NewMemoryStore returned nil")
	}
	if store.workspaceDir != filepath.Join(tmpDir, ".go-code-agent") {
		t.Errorf("workspaceDir = %s, want %s", store.workspaceDir, filepath.Join(tmpDir, ".go-code-agent"))
	}
}

func TestWriteMemory(t *testing.T) {
	tmpDir := t.TempDir()
	store := NewMemoryStore(tmpDir)

	tests := []struct {
		name        string
		content     string
		category    string
		expectError bool
	}{
		{
			name:        "正常写入",
			content:     "test memory content",
			category:    "fact",
			expectError: false,
		},
		{
			name:        "带类别写入",
			content:     "user preference: likes dark mode",
			category:    "preference",
			expectError: false,
		},
		{
			name:        "空内容",
			content:     "",
			category:    "fact",
			expectError: false, // 空内容也会写入，只是 token 可能为空
		},
		{
			name:        "超长内容",
			content:     strings.Repeat("a", infra.MaxMemoryContentLen+1),
			category:    "fact",
			expectError: true,
		},
	}

	for _, tt := range tests {
		t.Run(tt.name, func(t *testing.T) {
			result := store.WriteMemory(tt.content, tt.category)
			if tt.expectError {
				if !strings.Contains(result, "Error") {
					t.Errorf("WriteMemory(%q, %q) = %q, want error", tt.content, tt.category, result)
				}
			} else {
				if strings.Contains(result, "Error") {
					t.Errorf("WriteMemory(%q, %q) = %q, want success", tt.content, tt.category, result)
				}
			}
		})
	}
}

func TestTryReplaceDuplicate(t *testing.T) {
	tmpDir := t.TempDir()
	store := NewMemoryStore(tmpDir)

	// Write an initial memory. The two strings below share 3 of 4 unique
	// tokens (jaccard = 0.75) which is above DeduplicateThreshold (0.7),
	// so the second WriteMemory must replace the first instead of
	// appending a new entry.
	store.WriteMemory("original content stays here", "fact")

	result := store.WriteMemory("original content stays here also", "fact")
	if !strings.Contains(result, "updated") {
		t.Errorf("WriteMemory should detect and replace duplicate, got: %s", result)
	}
}

func TestLoadEvergreen(t *testing.T) {
	tmpDir := t.TempDir()
	store := NewMemoryStore(tmpDir)

	// MemoryStore reads MEMORY.md from {workspace}/.go-code-agent/, not
	// from the bare workspace dir. Mirror that layout so the test
	// actually exercises the loader instead of silently reading nothing.
	memoryContent := `# MEMORY

[preference] user likes dark mode
[lesson] always use context managers

plain fact about the project`
	memPath := filepath.Join(tmpDir, infra.AppRootDirName, "MEMORY.md")
	if err := os.MkdirAll(filepath.Dir(memPath), 0o755); err != nil {
		t.Fatalf("Failed to mkdir for MEMORY.md: %v", err)
	}
	if err := os.WriteFile(memPath, []byte(memoryContent), 0o644); err != nil {
		t.Fatalf("Failed to write MEMORY.md: %v", err)
	}

	result := store.LoadEvergreen()
	if result != memoryContent {
		t.Errorf("LoadEvergreen() = %q, want %q", result, memoryContent)
	}
}

func TestGetStats(t *testing.T) {
	tmpDir := t.TempDir()
	store := NewMemoryStore(tmpDir)

	// Same path note as TestLoadEvergreen — write under .go-code-agent/.
	memoryContent := `[preference] user likes dark mode`
	memPath := filepath.Join(tmpDir, infra.AppRootDirName, "MEMORY.md")
	if err := os.MkdirAll(filepath.Dir(memPath), 0o755); err != nil {
		t.Fatalf("Failed to mkdir for MEMORY.md: %v", err)
	}
	if err := os.WriteFile(memPath, []byte(memoryContent), 0o644); err != nil {
		t.Fatalf("Failed to write MEMORY.md: %v", err)
	}

	// Write to daily memory
	store.WriteMemory("daily fact", "fact")
	store.WriteMemory("another daily fact", "lesson")

	evergreenChars, dailyFiles, dailyEntries := store.GetStats()

	if evergreenChars == 0 {
		t.Error("GetStats should count evergreen characters")
	}
	if dailyFiles != 1 {
		t.Errorf("GetStats dailyFiles = %d, want 1", dailyFiles)
	}
	if dailyEntries != 2 {
		t.Errorf("GetStats dailyEntries = %d, want 2", dailyEntries)
	}
}

func TestDeleteMemory(t *testing.T) {
	tmpDir := t.TempDir()
	store := NewMemoryStore(tmpDir)

	// Write some memories
	store.WriteMemory("memory to delete", "fact")
	store.WriteMemory("keep this one", "lesson")

	// Delete the first memory
	result := store.DeleteMemory("memory to delete", "")
	if !strings.Contains(result, "Deleted") {
		t.Errorf("DeleteMemory failed: %s", result)
	}

	// Verify the deleted memory is gone
	_, _, dailyEntries := store.GetStats()
	// Should have 1 daily entry now (the lesson one)
	if dailyEntries != 1 {
		t.Errorf("DeleteMemory should remove the entry, got %d entries", dailyEntries)
	}
}

func TestHybridSearch(t *testing.T) {
	tmpDir := t.TempDir()
	store := NewMemoryStore(tmpDir)

	// Write various memories
	store.WriteMemory("user likes dark mode", "preference")
	store.WriteMemory("always use context managers", "lesson")
	store.WriteMemory("code review best practices", "fact")
	store.WriteMemory("API endpoint design", "context")

	// Search for "context managers"
	results := store.HybridSearch("context managers", 10)
	if len(results) == 0 {
		t.Error("HybridSearch should find results")
	}

	// Verify results are returned
	for _, r := range results {
		if r.Snippet == "" {
			t.Error("Result should have snippet")
		}
		if r.Score < 0 || r.Score > 1 {
			t.Errorf("Result score = %f, want in [0, 1]", r.Score)
		}
	}
}

func TestHybridSearchFiltered(t *testing.T) {
	tmpDir := t.TempDir()
	store := NewMemoryStore(tmpDir)

	// Write memories with different categories
	store.WriteMemory("preference content", "preference")
	store.WriteMemory("lesson content", "lesson")
	store.WriteMemory("fact content", "fact")

	// Category filter: every result's path label must carry the
	// [preference] tag (paths look like "2026-05-28.jsonl [preference]").
	results := store.HybridSearchFiltered("content", 10, 0, "preference")
	for _, r := range results {
		if !strings.Contains(r.Path, "[preference]") {
			t.Errorf("Filtered search should only return preference, got %s", r.Path)
		}
	}

	// Within-days filter: today's writes are within 1 day, so we expect
	// at least one hit.
	results = store.HybridSearchFiltered("content", 10, 1, "")
	if len(results) == 0 {
		t.Error("HybridSearchFiltered with withinDays=1 should still return today's writes")
	}
}

func TestFilterChunks(t *testing.T) {
	// Use dates relative to "today" so the within-days assertions hold
	// regardless of when the suite is run. The original test hard-coded
	// 2024-01-01 / 2024-01-15 dates, which silently broke the moment
	// real-world time advanced past those windows.
	now := time.Now().UTC()
	dayLabel := func(daysAgo int) string {
		return now.AddDate(0, 0, -daysAgo).Format("2006-01-02") + ".jsonl"
	}
	old := dayLabel(60)    // outside any reasonable within-days filter
	recent := dayLabel(2)  // within 7-day filter, outside 1-day filter
	chunks := []memoryChunk{
		{Path: "MEMORY.md [fact]", Text: "evergreen fact", Category: "fact"},
		{Path: old + " [fact]", Text: "old fact", Category: "fact"},
		{Path: recent + " [fact]", Text: "recent fact", Category: "fact"},
		{Path: recent + " [context]", Text: "recent context", Category: "context"},
	}

	// No filter
	result := filterChunks(chunks, 0, "")
	if len(result) != len(chunks) {
		t.Errorf("filterChunks with no filters = %d, want %d", len(result), len(chunks))
	}

	// Category filter
	result = filterChunks(chunks, 0, "fact")
	if len(result) != 3 {
		t.Errorf("filterChunks with category filter = %d, want 3", len(result))
	}

	// Within-days filter: 7 days keeps evergreen + recent fact + recent
	// context (3); old fact is excluded.
	result = filterChunks(chunks, 7, "")
	if len(result) != 3 {
		t.Errorf("filterChunks with 7-day filter = %d, want 3", len(result))
	}

	// Within-days filter: 1 day keeps only evergreen (no daily file is
	// from today in this fixture).
	result = filterChunks(chunks, 1, "")
	if len(result) != 1 {
		t.Errorf("filterChunks with 1-day filter = %d, want 1", len(result))
	}

	// Both filters: 30-day window + context category → only the recent
	// context chunk.
	result = filterChunks(chunks, 30, "context")
	if len(result) != 1 {
		t.Errorf("filterChunks with both filters = %d, want 1", len(result))
	}
}

func TestConcurrentAccess(t *testing.T) {
	tmpDir := t.TempDir()
	store := NewMemoryStore(tmpDir)

	// Concurrent writes
	writesDone := make(chan struct{})
	for i := 0; i < 10; i++ {
		go func(idx int) {
			store.WriteMemory(string(rune('a'+idx)), "fact")
			writesDone <- struct{}{}
		}(i)
	}
	for i := 0; i < 10; i++ {
		<-writesDone
	}

	// Concurrent reads — each reader must signal completion, otherwise
	// the wait loop below blocks forever (the original version reused a
	// single channel that the readers never sent on, deadlocking the
	// test until -timeout fired).
	readsDone := make(chan struct{})
	for i := 0; i < 10; i++ {
		go func() {
			store.HybridSearch("test", 10)
			readsDone <- struct{}{}
		}()
	}
	for i := 0; i < 10; i++ {
		<-readsDone
	}
}

// ========== 辅助函数 ==========

func equalStringSlices(a, b []string) bool {
	if len(a) != len(b) {
		return false
	}
	for i := range a {
		if a[i] != b[i] {
			return false
		}
	}
	return true
}

// ========== 缺失的测试用例 ==========

func TestCleanExpired(t *testing.T) {
	tmpDir := t.TempDir()
	store := NewMemoryStore(tmpDir)

	// Create a memory directory structure
	memoryDir := filepath.Join(store.memoryDir)
	
	// Create files from 30 days ago, 7 days ago, and today
	now := time.Now().UTC()
	oldDate := now.AddDate(0, 0, -30).Format("2006-01-02")
	weekAgo := now.AddDate(0, 0, -7).Format("2006-01-02")
	today := now.Format("2006-01-02")

	for _, date := range []string{oldDate, weekAgo, today} {
		path := filepath.Join(memoryDir, date+".jsonl")
		os.WriteFile(path, []byte("test content"), 0o644)
	}

	// Verify all files exist
	files, _ := filepath.Glob(filepath.Join(memoryDir, "*.jsonl"))
	if len(files) != 3 {
		t.Errorf("Expected 3 files, got 0", len(files))
	}

	// Clean expired (older than MemoryTTLDays, which is 90 days)
	// This should not remove anything yet
	store.cleanExpired()
	files, _ = filepath.Glob(filepath.Join(memoryDir, "*.jsonl"))
	if len(files) != 3 {
		t.Errorf("After cleanExpired, expected 3 files, got 0", len(files))
	}

	// Manually set MemoryTTLDays to 20 for testing
	// Note: This requires modifying infra consts or we just test the logic
	// by checking that files older than cutoff are removed
	cutoff := now.AddDate(0, 0, -20)
	files, _ = filepath.Glob(filepath.Join(memoryDir, "*.jsonl"))
	removed := 0
	for _, f := range files {
		base := strings.TrimSuffix(filepath.Base(f), ".jsonl")
		fileDate, err := time.Parse("2006-01-02", base)
		if err != nil {
			continue
		}
		if fileDate.Before(cutoff) {
			os.Remove(f)
			removed++
		}
	}
	if removed != 1 {
		t.Errorf("Expected to remove 1 file, removed 0", removed)
	}
}
